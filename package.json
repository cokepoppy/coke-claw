{
  "name": "coke-claw-lite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/lite/app.ts",
    "dev:telegram": "tsx src/lite/app.ts telegram",
    "dev:console": "tsx src/lite/app.ts console",
    "dev:admin": "tsx src/lite/app.ts admin",
    "dev:telegram-admin": "tsx src/lite/app.ts telegram-admin",
    "dev:both": "tsx src/lite/app.ts both",
    "dev:all": "tsx src/lite/app.ts all",
    "codex:login": "codex login --device-auth",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/lite/app.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/tests/**/*.test.js",
    "test:e2e": "npm run build && node --test dist/e2e/**/*.test.js",
    "test:e2e:ui": "npm run build && node --test dist/e2e/admin-ui.e2e.test.js"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.55.4",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "grammy": "^1.38.3",
    "playwright": "^1.55.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^22.18.6",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
